<%# ── Greeting ────────────────────────────────────────────────────── %>
<p style="margin:0 0 4px 0;font-size:15px;font-weight:600;color:#0d1b4b;">
  Hello, <%= @student.full_name %>.
</p>
<p style="margin:0 0 24px 0;font-size:14px;color:#4a5568;line-height:1.65;">
  You have a new message from the registrar on your escalation ticket.
</p>

<%# ── Ticket info card ────────────────────────────────────────────── %>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
       style="background-color:#f4f6ff;border-radius:10px;margin-bottom:20px;">
  <tr>
    <td style="padding:16px 20px;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
        <tr>
          <td>
            <span style="font-size:11px;font-weight:600;color:#5a6a9e;letter-spacing:0.8px;text-transform:uppercase;">
              Escalation Ticket
            </span>
            <span style="display:inline-block;margin-left:8px;background-color:#040F5F;color:#fff;font-size:11px;font-weight:700;padding:2px 10px;border-radius:999px;vertical-align:middle;">
              <%= @ticket.ticket_code %>
            </span>
          </td>
        </tr>
        <tr>
          <td style="padding-top:8px;font-size:14px;color:#1a1a2e;font-weight:500;">
            <%= @ticket.subject %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<%# ── Sender label ───────────────────────────────────────────────── %>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
       style="margin-bottom:8px;">
  <tr>
    <td style="vertical-align:middle;">
      <%# Sender avatar initial %>
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="display:inline-table;vertical-align:middle;">
        <tr>
          <td style="width:34px;height:34px;background-color:#1f47b7;border-radius:999px;text-align:center;vertical-align:middle;">
            <span style="color:#fff;font-size:14px;font-weight:700;line-height:34px;">
              <%= @sender.full_name.first.upcase %>
            </span>
          </td>
        </tr>
      </table>
      <span style="margin-left:10px;font-size:13px;font-weight:600;color:#1a1a2e;vertical-align:middle;">
        <%= @sender.full_name %>
      </span>
      <span style="margin-left:6px;font-size:12px;color:#8892b0;vertical-align:middle;">
        &middot; Registrar Staff
      </span>
    </td>
  </tr>
</table>

<%# ── Message bubble ─────────────────────────────────────────────── %>
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
       style="margin-bottom:28px;">
  <tr>
    <td style="background-color:#f4f6ff;border-left:4px solid #1f47b7;border-radius:0 10px 10px 0;padding:14px 18px;">
      <p style="margin:0;font-size:14px;color:#2d3748;line-height:1.7;white-space:pre-wrap;word-break:break-word;">
        <%= @message.body %>
      </p>
      <p style="margin:10px 0 0;font-size:11px;color:#a0aec0;">
        Sent <%= @message.created_at.strftime("%B %-d, %Y at %-I:%M %p") %>
      </p>
    </td>
  </tr>
</table>

<%# ── CTA button ─────────────────────────────────────────────────── %>
<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="border-radius:8px;background-color:#040F5F;">
      <a href="<%= @ticket_url %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;letter-spacing:0.2px;">
        View Ticket &rarr;
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0;font-size:12px;color:#a0aec0;line-height:1.6;">
  Log in to the E&#8209;Registrar portal to reply. Replies sent to this email address will not be received.
</p>
